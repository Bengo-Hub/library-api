# Library-API local development environment (copy to .env; NEVER commit real secrets)
APP_ENV=development
HTTP_PORT=4010

# Postgres (local PG17). Migrations use POSTGRES_MIGRATE_URL when set (direct, no pgbouncer).
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/library?sslmode=disable
POSTGRES_RUN_MIGRATIONS=false

# Redis
REDIS_ADDR=localhost:6380

# NATS / JetStream
EVENTS_NATS_URL=nats://localhost:4222
NATS_STREAM=library
OUTBOX_ENABLED=true

# Auth (SSO) — JWT validation + S2S
AUTH_SERVICE_URL=https://sso.codevertexitsolutions.com
AUTH_JWKS_URL=https://sso.codevertexitsolutions.com/api/v1/.well-known/jwks.json
AUTH_AUDIENCE=codevertex
# Shared S2S key (X-API-Key). Use a placeholder locally — real value injected from k8s secret.
INTERNAL_SERVICE_KEY=<REPLACE_ME>

# Downstream services
TREASURY_SERVICE_URL=https://booksapi.codevertexitsolutions.com
NOTIFICATIONS_SERVICE_URL=https://notificationsapi.codevertexitsolutions.com
SUBSCRIPTIONS_SERVICE_URL=https://pricingapi.codevertexitsolutions.com

# Media + e-book file store (PVC in prod)
MEDIA_ROOT=./media
EBOOK_ROOT=./media/ebooks
